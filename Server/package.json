{
  "name": "sports-event-backend",
  "version": "1.0.0",
  "description": "Backend for Sports Event Entry Web App",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "create-admin": "node scripts/createAdmin.js",
    "create-superadmin": "node scripts/createSuperAdmin.js",
    "create-coach": "node scripts/createCoach.js",
    "create-player": "node scripts/createPlayer.js",
    "create-competition": "node scripts/createCompetition.js",
    "test-email": "node test-email-services.js",
    "test-resend": "node test-resend-services.js",
    "migrate:up": "node scripts/migrate.js up",
    "migrate:down": "node scripts/migrate.js down",
    "migrate:status": "node scripts/migrate.js status"
  },
  "keywords": [
    "sports",
    "event",
    "entry",
    "node",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "nodemailer": "^7.0.12",
    "razorpay": "^2.9.6",
    "resend": "^6.10.0",
    "socket.io": "^4.7.4",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@ngrok/ngrok": "^1.7.0",
    "@types/jest": "^30.0.0",
    "fast-check": "^4.7.0",
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testTimeout": 30000,
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "maxWorkers": 1
  }
}
