# Database Configuration
MONGODB_URI=mongodb://localhost:27017/sports-event-app

# JWT Configuration
# CRITICAL: JWT_SECRET must be at least 32 characters long
# Generate a secure secret using:
#   Linux/Mac: openssl rand -base64 32
#   Windows: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
# NEVER commit your actual JWT_SECRET to version control!
JWT_SECRET=

# Server Configuration
PORT=5000
NODE_ENV=development

# Client Configuration
CLIENT_URL=http://localhost:5173

# Production URL (for CORS in production)
PRODUCTION_URL=https://mallakhamb-087p.onrender.com

# Email Configuration for Password Reset
# Gmail SMTP configuration - requires Gmail App Password
# Setup instructions:
# 1. Enable 2-factor authentication on your Gmail account
# 2. Go to Google Account → Security → 2-Step Verification → App passwords
# 3. Generate new app password for "Mail"
# 4. Use the generated 16-character password for EMAIL_PASS
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Frontend URL for password reset links
FRONTEND_URL=http://localhost:5173

# Ngrok Configuration
# Set to 'true' to enable ngrok tunnel on server start
NGROK_ENABLED=false
# Get your auth token from: https://dashboard.ngrok.com/get-started/your-authtoken
# Free tier allows 1 tunnel, paid plans allow multiple tunnels and custom domains
NGROK_AUTH_TOKEN=
