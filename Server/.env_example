# =========================
# Backend Environment Configuration
# =========================

# Database Configuration
MONGODB_URI=your_mongodb_connection_string_here

# JWT Configuration
# CRITICAL: JWT_SECRET must be at least 32 characters long
# Generate a secure secret using:
#   Linux/Mac: openssl rand -base64 32
#   Windows: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
# NEVER commit your actual JWT_SECRET to version control!
JWT_SECRET=your_jwt_secret_min_32_chars_here

# Server Configuration
PORT=5000

# =========================
# Environment Mode
# =========================

# Current runtime environment
# development → local testing
# production  → live deployment

# PRODUCTION (Render)
NODE_ENV=production

# LOCAL DEVELOPMENT (uncomment for local dev)
# NODE_ENV=development

# =========================
# Application URLs
# =========================

# PRODUCTION URLs (Render)
CLIENT_URL=https://mallakhamb-087p.onrender.com
FRONTEND_URL=https://mallakhamb-087p.onrender.com
PRODUCTION_URL=https://mallakhamb-087p.onrender.com

# LOCAL DEVELOPMENT URLs (uncomment for local dev)
# CLIENT_URL=http://localhost:5173
# FRONTEND_URL=http://localhost:5173
# PRODUCTION_URL=http://localhost:5173

# =========================
# Email Configuration
# =========================

# Gmail SMTP configuration - requires Gmail App Password
# Setup instructions:
# 1. Enable 2-factor authentication on your Gmail account
# 2. Go to Google Account → Security → 2-Step Verification → App passwords
# 3. Generate new app password for "Mail"
# 4. Use the generated 16-character password for EMAIL_PASS
EMAIL_USER=angreatharva08@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# =========================
# Ngrok Configuration
# =========================

# Set to 'true' to enable ngrok tunnel on server start
NGROK_ENABLED=false
# Get your auth token from: https://dashboard.ngrok.com/get-started/your-authtoken
# Free tier allows 1 tunnel, paid plans allow multiple tunnels and custom domains
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here
