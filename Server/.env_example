# =============================================================================
# Mallakhamb Competition Management System — Environment Configuration
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env_example .env
#
# NEVER commit your .env file to version control.
# The server will not start if required variables are missing or invalid.
# =============================================================================


# =============================================================================
# SERVER
# =============================================================================

# Port the HTTP server listens on
PORT=5000

# Runtime environment: development | production | test
# Controls logging format, CORS strictness, error detail level, and more.
NODE_ENV=development

# =============================================================================
# APPLICATION URLS
# =============================================================================

# Frontend URL — used for CORS and email reset links
# Development
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
PRODUCTION_URL=http://localhost:5173

# Production (uncomment and set for deployment)
# CLIENT_URL=https://your-frontend.onrender.com
# FRONTEND_URL=https://your-frontend.onrender.com
# PRODUCTION_URL=https://your-frontend.onrender.com

# Comma-separated list of allowed CORS origins (optional — overrides CLIENT_URL)
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
# CORS_ORIGINS=


# =============================================================================
# DATABASE
# =============================================================================

# MongoDB connection string (REQUIRED)
# Local:  mongodb://localhost:27017/sports-event-app
# Atlas:  mongodb+srv://<user>:<password>@cluster0.mongodb.net/sports-event-app
MONGODB_URI=your_mongodb_connection_string_here

# Connection pool settings (optional — defaults shown)
# Minimum number of connections to maintain in the pool
DB_POOL_MIN=10
# Maximum number of connections in the pool
DB_POOL_MAX=100
# Connection timeout in milliseconds
DB_CONNECT_TIMEOUT=10000
# Socket timeout in milliseconds
DB_SOCKET_TIMEOUT=45000


# =============================================================================
# JWT (JSON Web Tokens)
# =============================================================================

# JWT signing secret (REQUIRED)
# MUST be at least 32 characters long.
# Generate a secure secret:
#   Linux/Mac: openssl rand -base64 32
#   Windows:   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
# NEVER commit your actual JWT_SECRET to version control!
JWT_SECRET=your_jwt_secret_min_32_chars_here

# Token expiry duration (optional)
# Examples: 24h, 7d, 1h, 30m
JWT_EXPIRES_IN=24h


# =============================================================================
# EMAIL — Nodemailer (Gmail SMTP)
# =============================================================================

# Gmail address used as the sender
EMAIL_USER=your-email@gmail.com

# Gmail App Password (NOT your account password)
# Setup:
#   1. Enable 2-factor authentication on your Gmail account
#   2. Go to Google Account → Security → 2-Step Verification → App passwords
#   3. Generate a new app password for "Mail"
#   4. Paste the 16-character password here
EMAIL_PASS=your_gmail_app_password_here

# Email provider: nodemailer | resend (optional, default: nodemailer)
# EMAIL_PROVIDER=nodemailer

# SMTP host (optional, default: smtp.gmail.com)
# EMAIL_HOST=smtp.gmail.com

# SMTP port (optional, default: 587)
# EMAIL_PORT=587

# Use TLS (optional, default: false — uses STARTTLS on port 587)
# EMAIL_SECURE=false


# =============================================================================
# EMAIL — Resend (Recommended for Production)
# =============================================================================
# Better deliverability than Gmail SMTP. Free tier: 100 emails/day, 3,000/month.
#
# Setup:
#   1. Sign up at https://resend.com
#   2. Create an API key at https://resend.com/api-keys
#   3. Add and verify your sending domain (or use onboarding@resend.dev for testing)
#   4. Set EMAIL_PROVIDER=resend and fill in the values below

# Uncomment to enable Resend:
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_your_api_key_here

# Sender address (must be from a verified domain, or use onboarding@resend.dev for testing)
# RESEND_FROM_EMAIL=noreply@yourdomain.com


# =============================================================================
# SECURITY
# =============================================================================

# bcrypt salt rounds (optional, default: 12)
# Recommended range: 10–15. Higher = more secure but slower.
# BCRYPT_ROUNDS=12

# Maximum failed login attempts before account lockout (optional, default: 5)
# MAX_LOGIN_ATTEMPTS=5

# Account lockout duration in minutes (optional, default: 15)
# LOCKOUT_DURATION_MINUTES=15

# OTP length in digits (optional, default: 6, range: 4–8)
# OTP_LENGTH=6

# OTP expiry in minutes (optional, default: 10)
# OTP_EXPIRY_MINUTES=10


# =============================================================================
# RAZORPAY (Payment Gateway)
# =============================================================================
# Create keys at: https://dashboard.razorpay.com/app/keys
# Use test keys (rzp_test_*) for development, live keys for production.

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here


# =============================================================================
# CACHE
# =============================================================================

# Enable in-memory LRU cache (optional, default: true)
# ENABLE_CACHING=true

# Default cache TTL in seconds (optional, default: 300 = 5 minutes)
# CACHE_TTL_SECONDS=300

# Maximum number of items in the cache (optional, default: 1000)
# CACHE_MAX_SIZE=1000


# =============================================================================
# FEATURES & FEATURE FLAGS
# =============================================================================

# Enable metrics collection (optional, default: true)
# ENABLE_METRICS=true

# Feature flags as a JSON string (optional, default: {})
# Supports boolean flags and percentage-based rollouts.
# Example: FEATURES_FLAGS={"newScoringUI":true,"betaRegistration":{"percentage":20}}
# FEATURES_FLAGS={}


# =============================================================================
# MONITORING
# =============================================================================
# Health check endpoints are always available at:
#   GET /health/live    — liveness probe
#   GET /health/ready   — readiness probe
#   GET /health         — detailed health status
#   GET /health/metrics — performance metrics (JSON)
#   GET /health/metrics?format=prometheus — Prometheus format
#
# No additional configuration is required for health monitoring.
# The HealthMonitor and MetricsCollector are initialized automatically.


# =============================================================================
# NGROK (Development Tunneling)
# =============================================================================
# Exposes your local server to the internet for webhook testing.
# Only active when NGROK_ENABLED=true AND NODE_ENV=development.

# Set to 'true' to enable ngrok tunnel on server start
NGROK_ENABLED=false

# Get your auth token from: https://dashboard.ngrok.com/get-started/your-authtoken
# Required when NGROK_ENABLED=true
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here
