const getFilteredAgeGroups = (competition, gender) => {
  if (!competition?.ageGroups?.length) {
    return DEFAULT_AGE_GROUPS[gender] ?? [];
  }
  return competition.ageGroups
    .filter(ag => ag.gender === gender)
    .map(ag => ageGroupMapping[ag.ageGroup] ?? { value: ag.ageGroup, label: ag.ageGroup })
