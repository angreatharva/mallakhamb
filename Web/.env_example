# =========================
# Frontend Environment Configuration
# =========================

# Backend API URL
# For production on Render: https://mallakhamb.onrender.com/api
# For ngrok testing: https://your-ngrok-url.ngrok-free.app/api
# For local development: http://localhost:5000/api

# PRODUCTION (Render)
VITE_API_URL=https://mallakhamb.onrender.com/api

# NGROK TESTING (uncomment and update URL for ngrok testing)
# VITE_API_URL=https://your-ngrok-url.ngrok-free.app/api

# LOCAL DEVELOPMENT (uncomment for local dev)
# VITE_API_URL=http://localhost:5000/api

# =========================
# Security Configuration
# =========================

# Storage encryption key
# CRITICAL: Change this in production to a secure random string
# Generate a secure secret using:
#   Linux/Mac: openssl rand -base64 32
#   Windows: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
VITE_STORAGE_KEY=your_storage_encryption_key_here
