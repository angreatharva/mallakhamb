{
  "name": "mallakhambindia",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "pretest": "node -e \"require('fs').mkdirSync('coverage/.tmp',{ recursive: true })\"",
    "dev": "vite",
    "dev:host": "vite --host 0.0.0.0",
    "build": "vite build",
    "build:strict": "npm run test:a11y && npm run build",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint:staged": "lint-staged",
    "commit:nohooks": "git commit --no-verify",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:run:dot": "vitest run --reporter=dot",
    "test:a11y": "vitest run src/components/design-system/accessibility/design-system.a11y.test.jsx src/components/design-system/accessibility/keyboard-and-screenreader.a11y.test.jsx src/pages/accessibility-automated.test.jsx src/test/aria-contrast-validation.test.jsx",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --project=chromium --reporter=html,line",
    "prepare": "cd .. && node Web/node_modules/husky/bin.js"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,md,json,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-query": "^5.97.0",
    "@tanstack/react-query-devtools": "^5.97.0",
    "axios": "^1.15.0",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.23.25",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.546.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.48.2",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.20.1",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "web-vitals": "^5.2.0",
    "workbox-core": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "workbox-window": "^7.4.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "socket.io-parser": "4.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.0.16",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jsdom": "^27.3.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.32",
    "prettier": "^3.8.2",
    "prop-types": "^15.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^10.3.5",
    "storybook-dark-mode": "^5.0.0",
    "tailwindcss": "^3.3.6",
    "terser": "^5.46.0",
    "vite": "^7.1.7",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.16",
    "vitest-axe": "^0.1.0"
  }
}
